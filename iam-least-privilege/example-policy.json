{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListTargetBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "",
            "assets/*",
            "public/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowGetObjectsFromTargetBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:GetObjectTagging"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
      ]
    },
    {
      "Sid": "ExplicitDenyDestructiveActions",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:DeleteBucket",
        "s3:PutObject",
        "s3:PutBucketPolicy",
        "s3:PutBucketAcl",
        "s3:PutEncryptionConfiguration",
        "s3:PutBucketVersioning"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME",
        "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
      ]
    }
  ]
}
